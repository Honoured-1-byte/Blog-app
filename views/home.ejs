<!DOCTYPE html>
<html lang="en">

<head>
    <%- include('./partials/heads') %>
        <title>Homepage</title>
</head>

<body>
    <%- include('./partials/nav') %>
        <div class="container mt-3">
            <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 row-cols-xl-4 g-4">
                <% if (!blogs || blogs.length===0) { %>
                    <div class="col-12">
                        <div class="alert alert-info">No blogs yet. Create one via "Add Blog".</div>
                    </div>
                    <% } else { %>
                        <% blogs.forEach(blog=> { %>
                            <div class="col">
                                <div class="card h-100">
                                    <img src="<%= blog.coverImageURL %>" class="card-img-top" alt="<%= blog.title %>"
                                        style="height:200px; object-fit:cover;">
                                    <div class="card-body d-flex flex-column">
                                        <h5 class="card-title text-truncate">
                                            <%= blog.title %>
                                        </h5>
                                        <div class="mt-auto">
                                            <a href="/blog/<%= blog._id %>" class="btn btn-primary w-100">View</a>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <% }) %>
                                <% } %>
            </div>
        </div>
        <%- include('./partials/scripts') %>
</body>

</html>